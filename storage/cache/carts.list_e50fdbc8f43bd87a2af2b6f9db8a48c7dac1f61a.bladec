 data-food-description="<?php echo \htmlentities($food->description??'', ENT_QUOTES, 'UTF-8', false); ?>"
 data-cart-quantity="<?php echo \htmlentities($cart->quantity??'', ENT_QUOTES, 'UTF-8', false); ?>"
 data-cart-size-id="<?php echo \htmlentities($cart->size_id ?? ''??'', ENT_QUOTES, 'UTF-8', false); ?>"
 data-cart-topping-ids="<?php echo \htmlentities($cart->topping_ids ?? '[]'??'', ENT_QUOTES, 'UTF-8', false); ?>">
 <i class="fa fa-edit text-primary"></i>
 </button>
 </div>
 </td>
 </tr>
 <?php endforeach; $this->popLoop(); $loop = $this->getFirstLoop(); ?>
