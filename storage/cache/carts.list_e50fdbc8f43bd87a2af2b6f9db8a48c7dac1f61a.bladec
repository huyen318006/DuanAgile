 <div class="text-muted" style="font-size:12px;">+<?php echo \htmlentities(number_format($sizeObj->price, 0, ',', '.')??'', ENT_QUOTES, 'UTF-8', false); ?>đ</div>
 <?php else: ?>
 <span class="text-muted">N/A</span>
 <?php endif; ?>
 </td>
 <td>
 <?php if(!empty($cartToppings)): ?>
 <?php $__currentLoopData = $cartToppings; $this->addLoop($__currentLoopData);$this->getFirstLoop();
 foreach($__currentLoopData as $tp): $loop = $this->incrementLoopIndices();  ?>
 <div><?php echo \htmlentities($tp->name??'', ENT_QUOTES, 'UTF-8', false); ?> <span class="text-muted" style="font-size:12px;">(+<?php echo \htmlentities(number_format($tp->price, 0, ',', '.')??'', ENT_QUOTES, 'UTF-8', false); ?>đ)</span></div>
 <?php endforeach; $this->popLoop(); $loop = $this->getFirstLoop(); ?>
 <?php else: ?>
 <span class="text-muted">N/A</span>
 <?php endif; ?>
