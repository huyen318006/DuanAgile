<!DOCTYPE html>
<html lang="vi">

<head>
 <meta charset="UTF-8">
 <title>Đăng nhập - Food Order</title>

 <style>
 * {
 margin: 0;
 padding: 0;
 box-sizing: border-box;
 font-family: Arial, Helvetica, sans-serif;
 }

 /* Background */

 body {
 height: 100vh;
 display: flex;
 justify-content: center;
 align-items: center;

 background: linear-gradient(135deg, #ff7e5f, #feb47b);
 }

 /* Box login */

 .login-box {
 width: 380px;
 background: white;
 border-radius: 15px;
 box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
 overflow: hidden;
 animation: fadeIn 1s;
 }

 /* Title */

 .login-title {
 background: #ff5722;
 color: white;
 text-align: center;
 padding: 20px;
 font-size: 26px;
 font-weight: bold;
 }

 /* Form */

 form {
 padding: 30px;
 }

 .form-group {
 margin-bottom: 20px;
 }

 label {
 display: block;
 margin-bottom: 6px;
 color: #555;
 }

 input {
 width: 100%;
 padding: 12px;
 border-radius: 8px;
 border: 1px solid #ddd;
 transition: 0.3s;
 }

 /* Hover input */

 input:focus {
 border-color: #ff5722;
 outline: none;
 box-shadow: 0 0 5px rgba(255, 87, 34, 0.4);
 }

 /* Button */

 button {
 width: 100%;
 padding: 12px;
 border: none;
 border-radius: 8px;
 background: #ff5722;
 color: white;
 font-size: 16px;
 cursor: pointer;
 transition: 0.3s;
 }

 /* Hover button */

 button:hover {
 background: #e64a19;
 transform: scale(1.05);
 }

 /* Register text */

 .register {
 text-align: center;
 margin-top: 15px;
 font-size: 14px;
 }

 .register a {
 color: #ff5722;
 text-decoration: none;
 font-weight: bold;
 }

 .register a:hover {
 text-decoration: underline;
 }

 /* Animation */

 @keyframes fadeIn {
 from {
 opacity: 0;
 transform: translateY(20px);
 }

 to {
 opacity: 1;
 transform: translateY(0);
 }
 }
 </style>
</head>

<body>

 <div class="login-box">

 <div class="login-title">
 🍔 Đăng nhập Food Order
 </div>

 <form method="post" enctype="multipart/form-data" action="<?php echo \htmlentities(route('checklogin')??'', ENT_QUOTES, 'UTF-8', false); ?>">

 <div class="form-group">
 <label>Email</label>
 <input type="email" placeholder="Nhập email của bạn" name="email">
 </div>

 <div class="form-group">
 <label>Mật khẩu</label>
 <input type="password" placeholder="Nhập mật khẩu" name="password">
 </div>

 <button>Đăng nhập</button>

 <div class="register">
 Chưa có tài khoản?
 <a href="<?php echo \htmlentities(route('register')??'', ENT_QUOTES, 'UTF-8', false); ?>">Đăng ký</a>
 </div>
 <div class="login-link">
 <a href="<?php echo \htmlentities(route('forgotpassword')??'', ENT_QUOTES, 'UTF-8', false); ?>" class="forgot-link">Quên mật khẩu?</a>
 </div>
 <?php
 if (isset($_GET['error'])) {
 ?>
 <div style="color:white;background:red;padding:10px;border-radius:6px;margin-bottom:10px;">
 Sai email hoặc mật khẩu!
 </div>
 <?php } ?>

 </form>

 </div>

</body>

</html>