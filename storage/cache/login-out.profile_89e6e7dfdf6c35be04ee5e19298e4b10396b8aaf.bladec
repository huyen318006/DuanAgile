}

.profile-header{
background: linear-gradient(135deg,#ff9a44,#ff6a00);
color:white;
padding:50px 0;
}

.profile-avatar{
width:120px;
height:120px;
object-fit:cover;
border-radius:50%;
border:4px solid white;
}

.stat-box{
text-align:center;
}

.stat-number{
font-size:24px;
font-weight:bold;
color:#ff6a00;
}

.info-card{
background:#f8f9fa;
padding:15px;
